rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /siteConfig/{docId} {
      allow get: if docId == "global";
      allow list: if false;
      allow write: if docId == "global";
    }
  }
}
